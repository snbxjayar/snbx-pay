{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/setup", "destination": "/api/setup" },
    { "source": "/checkout", "destination": "/api/checkout" },
    { "source": "/payment-success", "destination": "/api/payment-success" },
    { "source": "/payment-cancel", "destination": "/api/payment-cancel" }
  ]
}